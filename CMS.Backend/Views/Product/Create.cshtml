@model CMS.Data.Entities.Product

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Thêm sản phẩm";
}

<div class="container mt-4">

    <div class="card shadow-sm border-0 rounded-3">

        <div class="card-header bg-success text-white">
            <h4 class="mb-0">
                <i class="bi bi-plus-circle"></i>
                THÊM SẢN PHẨM
            </h4>
        </div>

        <div class="card-body">

            <form asp-action="Create" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="row">

                    <div class="col-md-8">

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">
                                Tên sản phẩm
                            </label>

                            <input asp-for="Name"
                                   class="form-control"
                                   placeholder="Nhập tên sản phẩm..." />

                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold">
                                Mô tả sản phẩm
                            </label>

                            <textarea asp-for="Description"
                                      class="form-control"
                                      rows="5"
                                      placeholder="Nhập mô tả sản phẩm..."></textarea>

                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                    </div>

                    <div class="col-md-4">

                        <div class="mb-3">
                            <label asp-for="CategoryProductId" class="form-label fw-bold">
                                Danh mục sản phẩm
                            </label>

                            <select asp-for="CategoryProductId"
                                    class="form-select"
                                    asp-items="ViewBag.Categories">
                                <option value="">-- Chọn danh mục --</option>
                            </select>

                            <span asp-validation-for="CategoryProductId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Price" class="form-label fw-bold">
                                Giá sản phẩm
                            </label>

                            <input asp-for="Price"
                                   type="number"
                                   class="form-control"
                                   placeholder="Nhập giá sản phẩm..." />

                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="StockQuantity" class="form-label fw-bold">
                                Số lượng tồn kho
                            </label>

                            <input asp-for="StockQuantity"
                                   type="number"
                                   class="form-control"
                                   placeholder="Nhập số lượng..." />

                            <span asp-validation-for="StockQuantity" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                Ảnh sản phẩm
                            </label>

                            <input type="file"
                                   name="uploadImage"
                                   class="form-control"
                                   accept="image/*" />

                            <small class="text-muted">
                                Hỗ trợ: .jpg, .jpeg, .png, .gif, .webp
                            </small>
                        </div>

                    </div>

                </div>

                <hr />

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success px-4">
                        <i class="bi bi-check-circle"></i>
                        Lưu sản phẩm
                    </button>

                    <a asp-action="Index" class="btn btn-secondary px-4">
                        <i class="bi bi-arrow-left"></i>
                        Quay lại
                    </a>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}