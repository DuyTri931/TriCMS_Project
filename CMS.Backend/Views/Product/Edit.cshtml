@model CMS.Data.Entities.Product

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Cập nhật sản phẩm";
}

<div class="container mt-4">

    <div class="card shadow-sm border-0 rounded-3">

        <div class="card-header bg-warning text-dark">
            <h4 class="mb-0">
                <i class="bi bi-pencil-square"></i>
                CẬP NHẬT SẢN PHẨM
            </h4>
        </div>

        <div class="card-body">

            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <input type="hidden" asp-for="Id" />

                <div class="row">

                    <div class="col-md-8">

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">
                                Tên sản phẩm
                            </label>

                            <input asp-for="Name"
                                   class="form-control"
                                   placeholder="Nhập tên sản phẩm..." />

                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold">
                                Mô tả sản phẩm
                            </label>

                            <textarea asp-for="Description"
                                      class="form-control"
                                      rows="5"
                                      placeholder="Nhập mô tả sản phẩm..."></textarea>

                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                    </div>

                    <div class="col-md-4">

                        <div class="mb-3">
                            <label asp-for="CategoryProductId" class="form-label fw-bold">
                                Danh mục sản phẩm
                            </label>

                            <select asp-for="CategoryProductId"
                                    class="form-select"
                                    asp-items="ViewBag.Categories">
                                <option value="">-- Chọn danh mục --</option>
                            </select>

                            <span asp-validation-for="CategoryProductId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Price" class="form-label fw-bold">
                                Giá sản phẩm
                            </label>

                            <input asp-for="Price"
                                   type="number"
                                   class="form-control"
                                   placeholder="Nhập giá sản phẩm..." />

                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="StockQuantity" class="form-label fw-bold">
                                Số lượng tồn kho
                            </label>

                            <input asp-for="StockQuantity"
                                   type="number"
                                   class="form-control"
                                   placeholder="Nhập số lượng tồn kho..." />

                            <span asp-validation-for="StockQuantity" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                Upload ảnh mới
                            </label>

                            <input type="file"
                                   name="uploadImage"
                                   class="form-control"
                                   accept="image/*" />

                            <small class="text-muted">
                                Để trống nếu muốn giữ nguyên ảnh cũ.
                            </small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold d-block">
                                Ảnh hiện tại
                            </label>

                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <img src="@Model.ImageUrl"
                                     alt="Ảnh sản phẩm"
                                     class="img-thumbnail"
                                     style="max-height: 160px; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="text-muted">
                                    Chưa có ảnh sản phẩm.
                                </div>
                            }
                        </div>

                    </div>

                </div>

                <hr />

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning px-4 fw-bold">
                        <i class="bi bi-pencil-square"></i>
                        Cập nhật sản phẩm
                    </button>

                    <a asp-action="Index" class="btn btn-secondary px-4">
                        <i class="bi bi-arrow-left"></i>
                        Quay lại
                    </a>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}