@model IEnumerable<CMS.Data.Entities.OrderDetail>
@{
    Layout = "_LayoutAdmin"; ViewData["Title"] = "Quản lý chi tiết đơn hàng";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-dark fw-bold m-0">CHI TIẾT ĐƠN HÀNG TOÀN HỆ THỐNG</h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-file-earmark-plus"></i> Thêm sản phẩm vào ĐH
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-bordered table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 110px; text-align: center;">Mã Đơn Hàng</th>
                        <th>Tên sản phẩm chốt mua</th>
                        <th style="width: 100px; text-align: center;">Số lượng</th>
                        <th>Đơn giá tại thời điểm mua</th>
                        <th>Thành tiền sản phẩm</th>
                        <th class="text-center" style="width: 150px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center fw-bold text-danger">#@item.OrderId</td>
                            <td class="fw-bold">@(item.Product != null ? item.Product.Name : "Sản phẩm đã bị xóa khỏi hệ thống")</td>
                            <td class="text-center fw-bold">@item.Quantity</td>
                            <td class="text-secondary font-monospace">@item.UnitPrice.ToString("N0") VNĐ</td>
                            <td class="text-primary fw-bold font-monospace">@((item.Quantity * item.UnitPrice).ToString("N0")) VNĐ</td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Sửa</a>
                                <a asp-action="Delete" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-danger"
                                   onclick="return confirm('Bạn có thực sự chắc chắn muốn gỡ bỏ mặt hàng này khỏi đơn hàng không?')">Xóa</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>