@model CMS.Data.Entities.Post

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chỉnh sửa bài viết";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 rounded-3">

        <div class="card-header bg-warning text-dark py-3">
            <h5 class="fw-bold mb-0">
                <i class="bi bi-pencil-square me-2"></i>
                CHỈNH SỬA BÀI VIẾT
            </h5>
        </div>

        <div class="card-body p-4">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <input type="hidden" asp-for="Id" />

                <div class="row">

                    <div class="col-md-8 mb-3">
                        <label asp-for="Title" class="form-label fw-bold">
                            Tiêu đề bài viết
                        </label>

                        <input asp-for="Title"
                               class="form-control"
                               placeholder="Nhập tiêu đề bài viết..."
                               required />

                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="CategoryId" class="form-label fw-bold">
                            Chuyên mục bài viết
                        </label>

                        <select asp-for="CategoryId"
                                class="form-select"
                                asp-items="ViewBag.CategoryList"
                                required>
                            <option value="">-- Chọn chuyên mục --</option>
                        </select>

                        <span asp-validation-for="CategoryId" class="text-danger"></span>
                    </div>

                    <div class="col-12 mb-3">
                        <label asp-for="Content" class="form-label fw-bold">
                            Nội dung bài viết
                        </label>

                        <textarea asp-for="Content"
                                  class="form-control"
                                  rows="8"
                                  placeholder="Nhập nội dung chi tiết bài viết..."
                                  required></textarea>

                        <span asp-validation-for="Content" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-bold">
                            Upload ảnh mới
                        </label>

                        <input type="file"
                               name="uploadImage"
                               class="form-control"
                               accept="image/*" />

                        <small class="text-muted d-block mt-1">
                            Để trống nếu muốn giữ nguyên ảnh cũ.
                        </small>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-bold d-block">
                            Ảnh hiện tại
                        </label>

                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl"
                                 alt="Ảnh bài viết"
                                 class="img-thumbnail"
                                 style="max-height: 150px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="text-muted">
                                Chưa có ảnh đại diện.
                            </div>
                        }
                    </div>

                </div>

                <hr />

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning px-4 fw-bold">
                        <i class="bi bi-save me-1"></i>
                        Cập nhật bài viết
                    </button>

                    <a asp-action="Index" class="btn btn-secondary px-4">
                        <i class="bi bi-arrow-left me-1"></i>
                        Quay lại danh sách
                    </a>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js"></script>

    <script>
        ClassicEditor
            .create(document.querySelector('#Content'))
            .catch(error => {
                console.error(error);
            });
    </script>
}