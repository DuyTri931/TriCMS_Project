<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ThaiCMS Admin</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <style>
        .sidebar {
            min-height: 100vh;
            background-color: #212529;
            color: white;
        }

            .sidebar a {
                color: #adb5bd;
                text-decoration: none;
                display: block;
                padding: 10px 20px;
            }

                .sidebar a:hover {
                    background-color: #343a40;
                    color: white;
                }

            .sidebar .active {
                background-color: #0d6efd;
                color: white;
            }

            /* User area in sidebar */
            .sidebar .user-box {
                padding: 16px;
                border-bottom: 1px solid rgba(255,255,255,0.08);
                color: #e9ecef;
            }

                .sidebar .user-box .greeting {
                    font-size: 0.95rem;
                    margin-bottom: 4px;
                    color: #f8f9fa;
                }

                .sidebar .user-box .role {
                    display: block;
                    font-size: 0.85rem;
                    color: #ced4da;
                    margin-bottom: 10px;
                }

                .sidebar .user-box .btn-logout {
                    width: 100%;
                    padding: 6px 10px;
                }

        main {
            background-color: #fff;
            min-height: 100vh;
        }
    </style>
</head>

<body>
    <div class="container-fluid">
        <div class="row">

            <!-- SIDEBAR -->
            <nav class="col-md-3 col-lg-2 sidebar p-0">

                <!-- LOGO / TITLE -->
                <div class="p-3 text-center border-bottom border-secondary">
                    <h4 class="text-white mb-0">ThaiCMS Admin</h4>
                </div>

                <!-- USER INFO + LOGOUT -->
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <div class="user-box text-center">
                        <div class="greeting">
                            Chào, <strong>@User.FindFirst("FullName")?.Value</strong>
                        </div>

                        <span class="role">
                            (@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value)
                        </span>

                        <a class="btn btn-outline-danger btn-sm btn-logout"
                           asp-controller="Account"
                           asp-action="Logout">
                            Đăng xuất
                        </a>
                    </div>
                }

                <!-- MENU -->
                <div class="mt-3">
                    <a asp-controller="Home" asp-action="Index">
                        <i class="bi bi-speedometer2"></i> Bảng điều khiển
                    </a>

                    <a asp-controller="Category" asp-action="Index">
                        <i class="bi bi-grid"></i> Quản lý Danh mục
                    </a>

                    <a asp-controller="Post" asp-action="Index">
                        <i class="bi bi-file-earmark-post"></i> Quản lý Bài viết
                    </a>

                    <a asp-controller="User" asp-action="Index">
                        <i class="bi bi-people"></i> Quản lý Thành viên
                    </a>

                    <a asp-controller="CategoryProduct" asp-action="Index">
                        <i class="bi bi-grid"></i> Danh mục sản phẩm
                    </a>

                    <a asp-controller="Product" asp-action="Index">
                        <i class="bi bi-box-seam"></i> Sản phẩm
                    </a>

                    <a asp-controller="Customer" asp-action="Index">
                        <i class="bi bi-people"></i> Khách hàng
                    </a>

                    <a asp-controller="Order" asp-action="Index">
                        <i class="bi bi-grid"></i> Đơn hàng
                    </a>

                    <a asp-controller="OrderDetail" asp-action="Index">
                        <i class="bi bi-grid"></i> Đơn hàng chi tiết
                    </a>
                </div>
            </nav>

            <!-- CONTENT -->
            <main class="col-md-9 col-lg-10 p-4">
                @RenderBody()
            </main>

        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>